{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI Backend (8010)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8010"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
